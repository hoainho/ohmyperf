{
  "name": "@ohmyperf/viewer",
  "version": "0.0.0-pre",
  "description": "Static, single-file HTML viewer for OhMyPerf Reports (no runtime dependencies; no React in v0).",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "browser": "./dist/index.js"
    },
    "./charts": {
      "types": "./dist/charts/index.d.ts",
      "import": "./dist/charts/index.js",
      "browser": "./dist/charts/index.js"
    },
    "./escape": {
      "types": "./dist/escape.d.ts",
      "import": "./dist/escape.js",
      "browser": "./dist/escape.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "peerDependencies": {
    "@ohmyperf/core": "workspace:*",
    "@ohmyperf/design-tokens": "workspace:*"
  },
  "devDependencies": {
    "@ohmyperf/core": "workspace:*",
    "@ohmyperf/design-tokens": "workspace:*",
    "vitest": "catalog:"
  }
}
